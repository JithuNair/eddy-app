<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto Backup rules (Android 11 and below).
    Backed up to USER's own Google Drive — Eddy has zero access.
    Media files (photos, voice) are excluded from the 25MB cap;
    they survive APK upgrades on-device automatically.
-->
<full-backup-content>
    <!-- Hive boxes: habits, journal text/URLs/metadata (tiny, always back up) -->
    <include domain="file" path="." />
    <!-- Exclude large media — photos and voice notes survive in-place upgrades
         and would silently bust Android's 25MB backup limit -->
    <exclude domain="file" path="journal/photos" />
    <exclude domain="file" path="journal/voice" />
    <!-- Exclude Flutter internals -->
    <exclude domain="file" path="flutter_assets" />
</full-backup-content>
