<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ backup rules.
    App data is backed up to the USER's Google Drive only — no developer access.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="." />
        <exclude domain="file" path="flutter_assets" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="." />
        <exclude domain="file" path="flutter_assets" />
    </device-transfer>
</data-extraction-rules>
